{
  "name": "inside",
  "version": "1.0.0",
  "private": true,
  "description": "Inside - D1 기반 텍스트 커뮤니티 서비스 (Cloudflare Pages)",
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/tailwind.css --minify",
    "build": "npm run build:css",
    "dev:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/tailwind.css --watch",
    "dev": "npm run build:css && wrangler pages dev public --d1=DB --r2=IMAGES",
    "deploy": "npm run build && wrangler pages deploy public",
    "db:migrate:local": "wrangler d1 execute inside-db --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute inside-db --remote --file=./migrations/0001_init.sql",
    "hash-password": "node ./scripts/hash-password.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/webp": "^1.5.0"
  }
}
